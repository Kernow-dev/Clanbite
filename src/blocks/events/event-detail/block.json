{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanbite/event-detail",
	"version": "1.0.0",
	"title": "Event detail",
	"category": "clanbite",
	"icon": "info",
	"description": "Show a single scheduled event (title, schedule, venue or link, RSVP).",
	"textdomain": "clanbite",
	"attributes": {
		"eventId": {
			"type": "number",
			"default": 0
		}
	},
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanbite-event-detail",
		"color": ".wp-block-clanbite-event-detail",
		"typography": ".wp-block-clanbite-event-detail",
		"border": ".wp-block-clanbite-event-detail"
	}
}

{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanbite/player-profile-nav",
	"title": "Player Profile Navigation",
	"category": "clanbite-players",
	"icon": "groups",
	"description": "Displays the player profile subpage navigation.",
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true,
			"link": true
		},
		"html": false
	},
	"textdomain": "clanbite",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanbite-player-profile-nav",
		"color": {
			"text": ".wp-block-clanbite-player-profile-nav .clanbite-player-profile-nav__link",
			"background": ".wp-block-clanbite-player-profile-nav",
			"link": ".wp-block-clanbite-player-profile-nav .clanbite-player-profile-nav__link"
		},
		"typography": ".wp-block-clanbite-player-profile-nav .clanbite-player-profile-nav__link",
		"border": ".wp-block-clanbite-player-profile-nav"
	}
}

{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanbite/team-draws",
	"version": "1.0.0",
	"title": "Team draws",
	"category": "clanbite-teams",
	"icon": "minus",
	"description": "Displays the team’s draw count with optional prefix and postfix text.",
	"textdomain": "clanbite",
	"postTypes": [ "clanbite_team" ],
	"usesContext": [ "postId", "postType" ],
	"attributes": {
		"prefix": {
			"type": "string",
			"default": ""
		},
		"postfix": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true,
			"__experimentalDefaultControls": {
				"blockGap": true
			}
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false,
		"layout": {
			"allowSwitching": false,
			"allowInheriting": false,
			"default": {
				"type": "flex",
				"flexWrap": "wrap"
			}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanbite-team-draws",
		"color": ".wp-block-clanbite-team-draws",
		"typography": ".wp-block-clanbite-team-draws",
		"border": ".wp-block-clanbite-team-draws"
	}
}
